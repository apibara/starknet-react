{
  "name": "@starknet-react/core",
  "version": "3.0.0",
  "license": "MIT",
  "type": "module",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "default": "./dist/providers/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "default": "./dist/hooks/index.js"
    },
    "./query": {
      "types": "./dist/query/index.d.ts",
      "import": "./dist/query/index.js",
      "default": "./dist/query/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "lint": "biome check .",
    "lint:fix": "pnpm lint --apply",
    "format": "biome format . --write",
    "test": "vitest",
    "test:typecheck": "vitest typecheck"
  },
  "peerDependencies": {
    "get-starknet-core": "^4.0.0-next.2",
    "react": "^18.0",
    "starknet": "^6.1.5"
  },
  "dependencies": {
    "@starknet-react/chains": "workspace:^",
    "@tanstack/react-query": "^5.25.0",
    "eventemitter3": "^5.0.1",
    "immutable": "^4.3.4",
    "zod": "^3.22.4"
  },
  "repository": "apibara/starknet-react",
  "homepage": "https://starknet-react.com",
  "keywords": [
    "starknet",
    "ethereum",
    "l2"
  ],
  "devDependencies": {
    "@starknet-react/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "get-starknet-core": "^4.0.0-next.2",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^4.4.1",
    "starknet": "^6.1.5",
    "tsup": "^8.0.2",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^1.3.1"
  }
}
